<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="me.sunlianhui.coinflow.modules.category.mapper.AccountCategoryMapper">

    <resultMap id="BaseResultMap" type="me.sunlianhui.coinflow.modules.category.entity.AccountCategoryEntity">
        <id column="id" property="id"/>
        <result column="account_book_id" property="accountBookId"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="pid" property="pid"/>
        <result column="icon" property="icon"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT *
        FROM cf_account_category
        WHERE user_id = #{userId}
        ORDER BY sort_order ASC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT *
        FROM cf_account_category
        WHERE id = #{id}
    </select>

    <insert id="insert">
        INSERT INTO cf_account_category (id, user_id, account_book_id, name, type, pid, icon, sort_order, created_at, updated_at)
        VALUES (#{id}, #{userId}, #{accountBookId}, #{name}, #{type}, #{pid}, #{icon}, #{sortOrder}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update">
        UPDATE cf_account_category
        SET name       = #{name},
            type       = #{type},
            pid        = #{pid},
            icon       = #{icon},
            sort_order = #{sortOrder},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE
        FROM cf_account_category
        WHERE id = #{id}
    </delete>

</mapper>
